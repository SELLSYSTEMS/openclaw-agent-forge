#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export OPENCLAW_HOME="${ROOT}/.openclaw-home"
export PATH="${ROOT}/.openclaw/bin:${PATH}"

if [[ -f "${OPENCLAW_HOME}/openclaw-gateway.env" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "${OPENCLAW_HOME}/openclaw-gateway.env"
  set +a
fi

exec "${ROOT}/.openclaw/bin/openclaw" "$@"
